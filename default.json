{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Netresearch org-wide Renovate defaults",
  "extends": [
    "config:recommended"
  ],
  "stabilityDays": 3,
  "internalChecksFilter": "strict",
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": [
      "security"
    ]
  },
  "packageRules": [
    {
      "description": "Deny-list compromised axios versions (supply chain attack 2026-03-31)",
      "matchPackageNames": ["axios"],
      "allowedVersions": "!/^(1\\.14\\.1|0\\.30\\.4)$/"
    }
  ]
}
